# Template for .env — copy and adjust:
#   cp .env.example .env
#
# Used by both `dg dev` (local) and the deployed containers. Postgres
# connection details for the silver/gold plain-SQL assets (warehouse/resources.py).
# Bronze's MinIO + Postgres credentials live in .dlt/secrets.toml instead
# (dlt convention — see .dlt/secrets.example.toml).

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=evd_warehouse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
